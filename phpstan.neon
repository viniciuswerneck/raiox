parameters:
    level: 1
    paths:
        - app/Http/Controllers
        - app/Services
    excludePaths:
        - app/Services/Agents
        - app/Services/Territory
        - app/Services/CityDashboard
    ignoreErrors:
        - '#^Access to an undefined property#'
        - '#^Call to an undefined static method#'
        - '#^PHPDoc tag @method#'
    reportUnmatchedIgnoredErrors: false
